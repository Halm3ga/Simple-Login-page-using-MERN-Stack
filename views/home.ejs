<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | Autodesk</title>
    <style>
        body { font-family: sans-serif; margin: 20px; max-width: 900px; }
        nav a { margin-right: 15px; color: #0066cc; text-decoration: none; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { padding: 8px 12px; border: 1px solid #ccc; text-align: left; }
        thead { background: #0066cc; color: #fff; }
        .del-btn { padding: 7px 16px; background: #cc0000; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
        form { margin-top: 16px; display: flex; gap: 8px; flex-wrap: wrap; }
        form input { padding: 7px; border: 1px solid #ccc; border-radius: 4px; width: 160px; }
        form button { padding: 7px 16px; background: #0066cc; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
    </style>
</head>
<body>

    <nav>
        <a href="/home">Home</a>
        <a href="/login">Login</a>
    </nav>
    <hr>

    <h1>Home Page</h1>
    <p>Welcome to the Autodesk Next-Gen Creative Suite.</p>
    <hr>

    <h2>Products</h2>

    <% if (products.length === 0) { %>
        <p style="color:#888;">No products yet.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>ID</th>
                    <th>Price</th>
                    <th>Qty</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach((p, i) => { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td><%= p.prodName %></td>
                    <td><%= p.prodID %></td>
                    <td><%= p.prodPrice %></td>
                    <td><%= p.prodQuantity %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>

    <h3>Add Product</h3>
    <form action="/products" method="POST">
        <input type="text"   name="prodName"     placeholder="Name"     required>
        <input type="text"   name="prodID"        placeholder="ID"       required>
        <input type="number" name="prodPrice"     placeholder="Price"    required>
        <input type="number" name="prodQuantity"  placeholder="Qty"      required>
        <button type="submit">Add</button>
    </form>

    <h3>Delete Product</h3>
    <form action="/delete" method="POST">
        <input type="text" name="prodName" placeholder="Enter product name" required>
        <button type="submit" class="del-btn">Delete</button>
    </form>

</body>
</html>